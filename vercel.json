{
  "rewrites": [
    { "source": "/u/:slug/auth", "destination": "/api/index" },
    { "source": "/u/:slug",      "destination": "/api/index" },
    { "source": "/p/:slug/(.*)", "destination": "/api/index" },
    { "source": "/p/:slug",      "destination": "/api/index" },
    { "source": "/bot/:botId",   "destination": "/api/tg/:botId" }
  ],
  "functions": {
    "api/tg/[botId].js": {
      "maxDuration": 10
    }
  }
}
